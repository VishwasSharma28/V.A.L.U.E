# ─────────────────────────────────────────────────────────
# V.A.L.U.E Backend — Environment Variables
# Copy to .env.local and fill values
# ─────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/value_db

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ─── Frontend ───────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000

# ─── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Solana Blockchain ──────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Hex-encoded wallet private key (optional — local hash mode if absent)
SOLANA_WALLET_KEY=

# ─── Cloudinary ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=no-reply@value.app
