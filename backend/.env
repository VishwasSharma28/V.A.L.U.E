NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/value_db

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (generate strong secrets before going to production) ─
# Generate: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_ACCESS_SECRET=value_dev_access_secret_minimum_32_chars_long_1234567890
JWT_REFRESH_SECRET=value_dev_refresh_secret_minimum_32_chars_long_0987654321
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google OAuth ──────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ─── Frontend URL ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000

# ─── OpenAI (optional — falls back to rule-based if absent) ─
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Solana (optional — uses local hash if absent) ─────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WALLET_KEY=hex_encoded_private_key

# ─── Cloudinary (optional — uses stub URL if absent) ───────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ─── Email/SMTP (optional — logs to console if absent) ─────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app_password
# EMAIL_FROM=no-reply@value.app
